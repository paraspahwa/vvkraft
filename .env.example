# ── Fal.ai ─────────────────────────────────────────────────────────────────────
# Get your API key from https://fal.ai/dashboard
FAL_KEY=fal_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret used to verify incoming webhook payloads from fal.ai.
# Generate a strong random string (e.g. `openssl rand -hex 32`)
FAL_WEBHOOK_SECRET=replace_with_strong_random_secret

# ── Supabase (database) ───────────────────────────────────────────────────────
# Get these from your Supabase project dashboard (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL connection string for Better Auth (Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# ── Better Auth (authentication) ──────────────────────────────────────────────
# Secret used for signing session tokens (generate: openssl rand -hex 32)
BETTER_AUTH_SECRET=replace_with_strong_random_secret

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Backblaze B2 (object storage) ─────────────────────────────────────────────
B2_REGION=us-west-004
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=videoforge

# Public base URL for B2 objects (friendly download URL or CDN)
# e.g. https://f004.backblazeb2.com/file/videoforge
B2_PUBLIC_URL=

# ── Redis / BullMQ ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Razorpay (billing) ─────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Global (USD) plan IDs
RAZORPAY_PLAN_CREATOR_MONTHLY=
RAZORPAY_PLAN_CREATOR_YEARLY=
RAZORPAY_PLAN_PRO_MONTHLY=
RAZORPAY_PLAN_PRO_YEARLY=
RAZORPAY_PLAN_STUDIO_MONTHLY=
RAZORPAY_PLAN_STUDIO_YEARLY=
# India (INR) plan IDs
RAZORPAY_PLAN_CREATOR_MONTHLY_INR=
RAZORPAY_PLAN_CREATOR_YEARLY_INR=
RAZORPAY_PLAN_PRO_MONTHLY_INR=
RAZORPAY_PLAN_PRO_YEARLY_INR=
RAZORPAY_PLAN_STUDIO_MONTHLY_INR=
RAZORPAY_PLAN_STUDIO_YEARLY_INR=

# ── RunPod (GPU worker) ────────────────────────────────────────────────────────
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_3060=https://api.runpod.ai/v2/your-3060-endpoint
RUNPOD_ENDPOINT_4090=https://api.runpod.ai/v2/your-4090-endpoint
RUNPOD_ENDPOINT_A100=https://api.runpod.ai/v2/your-a100-endpoint

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── GPU Worker API ─────────────────────────────────────────────────────────────
WEBHOOK_BASE_URL=http://localhost:3000
WEBHOOK_SECRET=replace_with_strong_random_secret

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
